# ─────────────────────────────────────────────────────────────────────────────
# Construction ERP frontend — environment template. Copy to `.env.local`.
# Validated at boot by src/lib/config (zod, fail-fast in dev). See ADR-0003 §9.
# ─────────────────────────────────────────────────────────────────────────────

# ── PUBLIC (browser-visible) — NEVER put secrets or the NestJS host here ──
# The app's own origin (used to build absolute BFF URLs in tests/SSR).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── SERVER-ONLY (never NEXT_PUBLIC_*) ──
# The NestJS API base. The browser NEVER sees this — only the BFF route handlers
# call it. Keeping it server-only is an ADR-0003 F5 requirement.
NESTJS_API_BASE_URL=http://localhost:4000/api

# Secret used to sign/verify the CSRF double-submit token. Generate a long random
# value in real environments. Must be set; boot fails without it.
AUTH_CSRF_SECRET=dev-only-csrf-secret-change-me-0000000000000000

# Cookie behaviour. In production these MUST be Secure (https). "true"/"false".
AUTH_COOKIE_SECURE=false
# SameSite policy for the auth cookies: "lax" | "strict".
AUTH_COOKIE_SAMESITE=lax
