{
  "name": "ze-erp-nextjs-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Zakir Enterprise Construction ERP — Next.js (App Router) frontend. Scaffold per ADR-0003.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
